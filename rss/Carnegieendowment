24/ceip-header2024-lm.png" style="border: 0; display: block; text-decoration: none; height: auto; width: 100%; font-size: 13px;" width="600" /&gt;&lt;/a&gt; &lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;!--[if !mso]&gt;&lt;!--&gt;&lt;tr&gt;&lt;td align="center" class="dark_img" style="font-size: 0px; padding: 0; display: none;"&gt;&lt;table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse; border-spacing: 0px;"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td style="width: 600px;"&gt; &lt;a href="https://go.carnegieendowment.org/ODEzLVhZVS00MjIAAAGiVxwiaOAdzrrGSib1BG2wZfHefIwcj_pC4TzoIXW9tMRyF2WgQhDiYDPWBShgXNESPCoD468=" target="_blank"&gt;&lt;img alt="卡内基国际和平基金会" class="mktoImg" height="auto" id="logoImgDark" src="https://ceipimg.s3.amazonaws.com/email/2024/ceip-header2024-dm.png" style="border: 0; display: block; text-decoration: none; height: auto; width: 100%; font-size: 13px;" width="600" /&gt;&lt;/a&gt; &lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;!--&lt;![endif]--&gt;&lt;tr&gt;&lt;td style="font-size: 0px;"&gt;&lt;div style="height: 60px; line-height: 60px;"&gt;&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;!--[if mso | IE]&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;![endif]--&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;!--[if mso | IE]&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;![endif]--&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr class="mktoModule" id="BodyText"&gt;&lt;td&gt;&lt;!--[if mso | IE]&gt;&lt;table align="center" border="0" cellpadding="0" cellspacing="0" class="" role="presentation" style="width:600px;" width="600" bgcolor="#FFFFFF" &gt;&lt;tr&gt;&lt;td style="line-height:0px;font-size:0px;mso-line-height-rule:exactly;"&gt;&lt;![endif]--&gt;&lt;div style="background-color: #FFFFFF; margin: 0px auto;"&gt;&lt;table align="center" border="0" cellpadding="0" cellspacing="0" style="background-color: #FFFFFF; width: 100%;"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td style="direction: ltr; font-size: 0px; padding: 0; text-align: center;"&gt;&lt;!--[if mso | IE]&gt;&lt;table role="presentation" border="0" cellpadding="0" cellspacing="0"&gt;&lt;tr&gt;&lt;td class="" style="vertical-align:top;width:600px;" &gt;&lt;![endif]--&gt;&lt;div class="mj-column-per-100 mj-outlook-group-fix" style="font-size: 0px; text-align: left; direction: ltr; display: inline-block; vertical-align: top; width: 100%;"&gt;&lt;table border="0" cellpadding="0" cellspacing="0" style="vertical-align: top;" width="100%"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td align="left" class="text-color-adjust" style="font-size: 0px; padding: 10px 25px;"&gt;&lt;div style="font-family: Georgia, serif; font-size: 17px; line-height: 28px; text-align: left; color: #000000;"&gt;&lt;div class="mktoText" id="BodyContentText"&gt;&lt;p&gt;亲爱的同事们，&lt;/p&gt;&lt;p&gt;我很高兴地宣布，董事会已选举艾薇儿·海恩斯为卡内基国际和平基金会第十一任主席。&lt;/p&gt;&lt;p&gt;艾薇儿带来了非凡的公共服务记录，并对指导卡内基一个多世纪的原则做出了坚定的承诺。经两党广泛支持确认，艾薇儿担任拜登总统领导下的第七任国家情报总监。她此前还曾担任国家安全高级职务，包括奥巴马白宫首席副国家安全顾问、中央情报局副局长以及参议院外交关系委员会副首席法律顾问。在跨越政府所有三个部门和学术界的数十年服务中，她赢得了学术诚实的声誉，并坚信最高权力层做出的决策绝不能忽视其所影响的人民。&lt;/p&gt;&lt;p&gt;艾薇儿目前在哥伦比亚大学和牛津大学任职，她是万灵学院的研究员，从事国家安全决策的道德文化研究——这项工作符合卡内基的使命。&lt;/p&gt;&lt;p&gt;艾薇儿将于 9 月 28 日上任。我和受托人非常高兴地欢迎艾薇儿来到卡内基，并期待她的愿景在未来数月乃至数年中得以实现。&lt;/p&gt;&lt;p&gt;请阅读我们的&lt;a href="https://go.carnegieendowment.org/ODEzLVhZVS00MjIAAAGiVxwiaOf5Ihlhxz09ye3j_jO0OEW3eysrUlplqnhmOhs80F7Ij85EhFbuhYPV-G4QNi3xlVQ=" id="" style="color: #00365e;" target="_blank"&gt;新闻稿&lt;/a&gt;以及&lt;em&gt;&lt;a href="https://go.carnegieendowment.org/ODEzLVhZVS00MjIAAAGiVxwiaIPXfkQMWkEfsSLUFaH42A1hb3MFEL5MWS9BArLzz-RHOtsLMUPrNjRwEN1ywkKJN2Q=" id="" style="color: #00365e;" target="_blank"&gt;《纽约时报》&lt;/a&gt;&lt;/em&gt;的报道，详细了解她的背景。感谢您的支持。请和我们一起欢迎艾薇儿来到卡内基！&lt;/p&gt;&lt;p&gt;真挚地，&lt;/p&gt;&lt;p&gt;简·哈特利&lt;br /&gt;董事会主席&lt;br /&gt;卡内基国际和平基金会&lt;br /&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;!--[if mso | IE]&gt;&lt;/td&g