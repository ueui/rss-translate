t-size: 0px; padding: 30px; text-align: center;"&gt;&lt;!--[if mso | IE]&gt;&lt;table role="presentation" border="0" cellpadding="0" cellspacing="0"&gt;&lt;![endif]--&gt;&lt;!-- boxed annoucements body text --&gt;&lt;!--[if mso | IE]&gt;&lt;tr&gt;&lt;td class="" width="600px" &gt;&lt;table align="center" border="0" cellpadding="0" cellspacing="0" class="" role="presentation" style="width:540px;" width="540" bgcolor="#FFFFFF" &gt;&lt;tr&gt;&lt;td style="line-height:0px;font-size:0px;mso-line-height-rule:exactly;"&gt;&lt;![endif]--&gt;&lt;div style="background-color: #FFFFFF; margin: 0px auto;"&gt;&lt;table align="center" border="0" cellpadding="0" cellspacing="0" style="background-color: #FFFFFF; width: 100%;"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td style="direction: ltr; font-size: 0px; padding: 0; text-align: center;"&gt;&lt;!--[if mso | IE]&gt;&lt;table role="presentation" border="0" cellpadding="0" cellspacing="0"&gt;&lt;tr&gt;&lt;td class="" style="vertical-align:top;width:540px;" &gt;&lt;![endif]--&gt;&lt;div class="mj-column-per-100 mj-outlook-group-fix" style="font-size: 0px; text-align: left; direction: ltr; display: inline-block; vertical-align: top; width: 100%;"&gt;&lt;table border="0" cellpadding="0" cellspacing="0" width="100%"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td style="background-color: #FFFFFF; vertical-align: top; padding: 30px 0px 10px;"&gt;&lt;table border="0" cellpadding="0" cellspacing="0" width="100%"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td align="left" class="text-color-adjust boxed-announcement-text" style="font-size: 0px; padding: 10px 25px;"&gt;&lt;div style="font-family: Georgia, serif; font-size: 17px; line-height: 24px; text-align: left; color: #000000;"&gt;&lt;div class="mktoText" id="BoxedAnnoucmentTextb9ecf55f-aaa5-4301-8e10-47b3a37f6d91"&gt;&lt;div&gt; &lt;strong class="boxed-announcement-title" style="font-family: 'Inter Tight', helvetica, arial, sans-serif; font-size: 20px; color: #00a79d;"&gt;冷战后的太空、核武器和美俄关系&lt;/strong&gt;&lt;/div&gt;&lt;p&gt;在俄罗斯官方的叙述中，冷战结束后的美国决心将北约扩展到俄罗斯边境，对俄罗斯国家构成生存威胁。历史记录证明事实并非如此。从乔治·H·W·布什开始，历届美国总统都坚信与俄罗斯的合作对于国际安全至关重要，并制定了加强美俄关系的政策。近二十年来，随着俄罗斯和美国在外太空、反恐和核能方面的合作，这一战略产生了有意义的合作。&lt;/p&gt;&lt;p&gt;虽然今天与90年代截然不同，但从这段合作时期可以汲取哪些经验教训？一旦乌克兰实现公平和平，俄罗斯弥补其造成的损害，是否值得恢复合作？&lt;/p&gt;&lt;p&gt; &lt;strong&gt;5 月 27 日星期三上午 10:00，&lt;/strong&gt;卡内基核政策项目非常驻研究员、北约前副秘书长 Rose Gottemoeller 与 NPR 外交记者 Michele Keleman 进行面对面或在线对话，探讨 Gottemoeller 如何在她的新书&lt;em&gt;《通过合作实现安全&lt;/em&gt;》中解决这些问题。 &lt;/p&gt;&lt;div&gt;&lt;br /&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;!--[if mso | IE]&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;![endif]--&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;!--[if mso | IE]&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;![endif]--&gt;&lt;!-- boxed annoucements buttons --&gt;&lt;!--[if mso | IE]&gt;&lt;tr&gt;&lt;td class="" width="600px" &gt;&lt;table align="center" border="0" cellpadding="0" cellspacing="0" class="" role="presentation" style="width:540px;" width="540" bgcolor="#FFFFFF" &gt;&lt;tr&gt;&lt;td style="line-height:0px;font-size:0px;mso-line-height-rule:exactly;"&gt;&lt;![endif]--&gt;&lt;div style="background-color: #FFFFFF; margin: 0px auto;"&gt;&lt;table align="center" border="0" cellpadding="0" cellspacing="0" style="background-color: #FFFFFF; width: 100%;"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td style="direction: ltr; font-size: 0px; padding: 0; text-align: center;"&gt;&lt;!--[if mso | IE]&gt;&lt;table role="presentation" border="0" cellpadding="0" cellspacing="0"&gt;&lt;tr&gt;&lt;td class="" style="vertical-align:top;width:270px;" &gt;&lt;![endif]--&gt;&lt;div class="mj-column-per-50 mj-outlook-group-fix" style="font-size: 0px; text-align: left; direction: ltr; display: inline-block; vertical-align: top; width: 100%;"&gt;&lt;table border="0" cellpadding="0" cellspacing="0" class="mktoText" id="buttonEditableAnnouncemenTeald1fb05c3-382d