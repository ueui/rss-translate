BFdfxIU/i2iyWdP1ZlHs/v9/-1x-1.png" style="width: 80px; height: 80px; border-radius: 8px; display: block;" width="80" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;/div&gt;&lt;div style="margin-top: 12px; margin-left: 12px;"&gt;&lt;p style="font-weight: 700; line-height: 1.4; margin: 0; color: inherit; text-decoration: none; font-size: 16px !important;"&gt;零&lt;/p&gt;&lt;p style="line-height: 1.4; margin: 4px 0 0 0; color: inherit; text-decoration: none; font-size: 16px !important;"&gt;伊朗战争将重塑能源的未来&lt;/p&gt;&lt;/div&gt;&lt;a href="https://links.message.bloomberg.com/a/sc/3RrYKG7IwhJqjNokLcXIxXdMGi7I2xZpYL3Fbv6rLXs7gZyepnurVtWaXhefQ_o8L2R7_upxScCY_xKAsuwB8giL1ow7WhtU_KSmg2S14VYJfA0C-2lYAHlD_Okgg91Jc6vd-oXUFGpruoQRmBaqm_UvArulCRuyJyFWZFnmx66Q17_0_8XZsuxRWhV-uq0n6fFLfzOjHsRIe-zRMPbtMcM6nMiO-Kb-qLBqIQdAL38jQ7TgZk7RA4peJy5bRg4_GZ6lyMlzCgh_FrhJxIxPb4xHrRcW_5hmARHMxhkW5ecS6eMBkoPZZdtQoS8hN-P6A5DfNYPesrzCZ6u5DDakUybwaUpBNc1InYgTcziuy2sWngotzswu2j2dM-VcN4IJbYXsaw/4LKpzcshPOFoqQa8s6vqtlQl0xDIq--P/19" style="margin-top: 12px; display: flex; font-size: inherit; color: inherit; text-decoration: none;" target="_blank"&gt;&lt;!--[if mso]&gt;&lt;table width="580"&gt;&lt;tr&gt;&lt;td&gt;&lt;img src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iqN.OaQUf0is/v0/-1x-1.png" alt="Listen Now" width="580"/&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;div style="display:none"&gt;&lt;![endif]--&gt;&lt;img alt="立即收听" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iqN.OaQUf0is/v0/-1x-1.png" style="width: 100%; display: block; margin-bottom: 4px;" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;/a&gt;&lt;/div&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;自2月28日美国和以色列对伊朗发动袭击以来，全球能源市场一直处于疯狂状态，价格随着每一个新的头条新闻而上下波动。即使霍尔木兹海峡有望重新开放，世界各地的石油和天然气价格仍然上涨，我们开始看到对当地经济的影响，特别是亚洲的经济。本周，彭博社观点专栏作家戴维·菲克林 (David Fickling) 在《零》节目中解释了这些影响是什么，以及它们将如何在未来几十年重塑亚洲的能源系统。&lt;/p&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt; &lt;a href="https://links.message.bloomberg.com/s/c/7i