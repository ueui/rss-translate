M4Lzm5nCbGtyepqEBqbs8jzkToRvLtLbGbsG341e1Zg0viTLhrgrioKtIt3d02QF38vjy8lTk3b51B0wUcSBNj8sAwBs5z9iDAblyHv98HcLs2w_f0WmP9dixDBXzN157ysjBXGe7nHSvwr/hV3eG3SoGDAWgL11qP6c4hsePQODWBxd/22" rel="noopener noreferrer" style="font-size: inherit; color: #00e;" target="_blank" title="曹东 |彭博社"&gt;曹东&lt;/a&gt;、 &lt;a href="https://links.message.bloomberg.com/s/c/tqQTumbHNhICN-nnqHP0USJ20yZEftPxu8B3dJ8OIN-hsxde7uZcv5BEgPQR0sX4ZDuWeHvjQQxEOeNZp6oyAmpcW7QXn7i0de7gzv-xdGxvLCROEk3R76pmycygQfiiuH7Ic0Vut7pGp7Yyx2jKWvqjDet6ZKA2uX1wAruQM6FLqyKUMQzmd6jq1wTlRJD8yi150Y4sa1iNyunw9Zk8a2C03WPNwIZ8Nh-yAeeQgjZU-6YFR0i78cus1lyKFn1Z5goFLTv7JO1skt5iINdpxXeUyGuVXBqaYuJdytSsbyl3jDkzq_4ocXhVmLtv1tXzqyuV9qKfDnRDAt4UKpBXmcBE8oUjmQbS1S2-veA7xm8LJDpfndSslFTaaNMsgMSQTZJbxmkTeaTc6SlFlNhfcwHPV4UO6x8TqrMjpCo-lbiVOXz9x-dD97Tgdx8RylNczJCittz--bdI0Km7Vq-i_cqz_708bniAZ9c9U2IB/JVDpnYIz3YfUJNCDTCpAnKg896l21g-P/22" rel="noopener noreferrer" style="font-size: inherit; color: #00e;" target="_blank" title="雾霾风扇|彭博社"&gt;Haze Fan&lt;/a&gt;&lt;/p&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;费尔南多-迪诺罗尼亚群岛周围环绕着碧绿的大西洋海水，点缀着本土无花果树，是巴西最令人向往的旅游目的地之一。这里居住着大约 3,000 名居民，每年接待的游客数量大约是这个数字的 40 倍，这给主要靠船载柴油维持供电的孤立电网带来了巨大压力。&lt;/p&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;随着&lt;a href="https://links.message.bloomberg.com/a/sc/3zyHkG-zkHbdaOomyPku6tuzpPkqdthNjurS5rf2j9_W0uKBRo153z3LxLZHttzLbHT8xs6eG5gVIeKW_jayI1bDdD8OR7Ow55qICWBTYXCa08a7jEburPNUXJEA-_WMEWjRLciqB3Dtoh60p-5JQew0jUpdvfWshx3o3S0Wm37J-WpxRv33vNbV8WkUXGoFl7oy1-xQ8QO42bArFqfwCrAU_bMJpfD7jB9BnDCuWMl9Yuq-NCSP0g09v_mP-LXM9hON4ZJpDrMVlgkzj5BqTIp3QAzOjTtF9In8PAOG4QO_LIWG43TDYRdX2DOIwNla4inRAPtYKvqWvEgNZtt27LdjiQ07hcf8qBkF3VLzXuvhgUmFGNFBiFEmVsxTbvwxLpVZMMtOlwfqccf0gcV5I0CptPM4pn4_hhn1eAFF564W1pRtSEtOIT1FxWce8hRKuGg4G9nKW0cLw26HbMc-9cd8MRrbjs_f0uIDmgzoaYli3x_5KLmJY4CtcQPgk4BhXbO4700977Eo9vNKfJ5slpHCUvtbbANzDLwQrxLmfgV0xfJBYWcRsmJpgHdQgpOQ3Sqm7vAj1Q/5Bj7bpIuG8NqKC-igTWjdZEZP1XKdlGQ/22" rel="noopener noreferrer" style="font-size: inherit; color: #00e;" target="_blank" title="华为110亿美元的清洁能源帝国正在开拓新市场"&gt;拉丁美洲最大的能源存储项目之一的&lt;/a&gt;安装，这种压力将在今年晚些时候得到缓解。设备供应商包括华为技术有限公司。 &lt;/p&gt;&lt;figure style="margin: 20px 0;"&gt;&lt;!--[if mso]&gt;&lt;table width="580"&gt;&lt;tr&gt;&lt;td&gt;&lt;img src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iboF1t37KinM/v1/-1x-1.jpg" alt="Baia do Sancho, one of Brazil&amp;amp;#39;s most beautiful beaches, located on Fernando de Noronha, is shown in this photo taken in January 2009. The island, a Unesco World Heritage site, is an eco-paradise that offers pristine sand, turquoise waters and friendly sea creatures such as dolphins and turtles. Photographer: Robert Hilferty&amp;amp;#x2F;Bloomberg News" width="580"/&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;div style="display:none"&gt;&lt;![endif]--&gt;&lt;img alt="这张照片拍摄于 2009 年 1 月，巴亚杜桑乔 (Baia do Sancho) 是巴西最美丽的海滩之一，位于费尔南多迪诺罗尼亚群岛。该岛被联合国教科文组织列为世界遗产，是一个生态天堂，拥有原始的沙滩、碧绿的海水和友好的海洋生物，如海豚和海龟。摄影师：罗伯特·希尔弗蒂&amp;amp;#x2F;彭博新闻" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iboF1t37KinM/v1/-1x-1.jpg" style="width: 100%; display: block; margin-bottom: 4px;" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;figcaption&gt;&lt;div style="font-size: 14px; line-height: 1.4;"&gt;费尔南多-迪诺罗尼亚群岛的桑乔湾 (Baia do Sancho)&lt;/div&gt;&lt;/figcaption&gt;&lt;div style="font-size: 14px; line-height: 1.4; font-style: italic;"&gt;摄影师：Robert Hilferty/彭博新闻，来自 VIA BLOOMBERG NEWS&lt;/div&gt;&lt;/figure&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;这家总部位于深圳的巨头以其智能手机和 5G 电信基础设施而闻名，近年来悄然将自己定位为全球能源转型支柱的一部分。其清洁能源帝国华为数字能源技术有限公司提供从电池存储、太阳能逆变器到电动汽车充电服务的一切产品。随着美国和欧洲变得更加敌对，巴西等新兴市场对企业来说变得越来越重要。&lt;br /&gt;&lt;br /&gt;华为数字能源去年的销售额超过 110 亿美元，在母公司 1260 亿美元的总收入中所占的份额相对较小。尽管如此，就规模而言，它与特斯拉公司的能源部门或中国本土可再生能源设备领导者阳光电源股份有限公司相差不远，这两家公司的 2025 年销售额约为 130 亿美元。 &lt;/p&gt;&lt;figure style="margin: 20px 0;"&gt;&lt;!--[if mso]&gt;&lt;table width="580"&gt;&lt;tr&gt;&lt;td&gt;&lt;img src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iiCDvNo1aW8s/v2/-1x-1.jpg" alt="Huawei Technologies Co. equipment next to photovoltaic panels at a solar farm operated by Yellow River Power in Gonghe County, Qinghai province, China, on Monday, Sept. 27, 2021. China, the world&amp;amp;#39;s biggest greenhouse gas emitter, cant meet its environmental goals without connecting its abundant sources of renewable energy with its coastal megacities." width="580"/&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;div style="display:none"&gt;&lt;![endif]--&gt;&lt;img alt="2021 年 9 月 27 日星期一，中国青海省共和县黄河电力运营的太阳能发电厂的光伏板旁边，华为技术有限公司的设备。中国是世界上最大的温室气体排放国，如果不将其丰富的可再生能源与其沿海特大城市连接起来，就无法实现其环境目标。" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iiCDvNo1aW8s/v2/-1x-1.jpg" style="width: 100%; display: block; margin-bottom: 4px;" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;figcaption&gt;&lt;div style="font-size: 14px; line-height: 1.4;"&gt;中国青海省一座太阳能发电场的华为设备。&lt;/div&gt;&lt;/figcaption&gt;&lt;div style="font-size: 14px; line-height: 1.4; font-style: italic;"&gt;摄影师：&lt;em style="font-size: 14px; line-height: 1.4; font-style: italic;"&gt;沉其来/彭博社&lt;/em&gt;&lt;/div&gt;&lt;/figure&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;该部门也是多元化和增长的有用来源。自2019年美国对华为实施全面制裁以来，华为的尖端路由器和基站实际上已在西方大部分地区被禁止，而其全球出货量一度超过三星电子和苹果公司的智能手机业务已跌出全球前五名。去年，整体收入仅增长2%，为三年来最低，而华为数字电源的收入却实现了两位数增长。&lt;br /&gt;&lt;br /&gt;知情人士称，华为也在探索其他方式将其能源业务货币化，包括最近试图将该部门出售给当代新能源科技有限公司，但由于该部门的估值而失败。其中一位知情人士补充说，华为寻求至少 2000 亿元人民币（295 亿美元），而全球最大的电池制造商宁德时代对该部门的估值接近 1500 亿元人民币。&lt;/p&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;宁德时代发言人表示，该公司无意收购该业务，也没有讨论收购事宜。华为没有回应置评请求。 &lt;/p&gt;&lt;figure style="margin: 20px 0;"&gt;&lt;!--[if mso]&gt;&lt;table width="580"&gt;&lt;tr&gt;&lt;td&gt;&lt;img src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iu0tXeBoEQ5M/v3/pidjEfPlU1QWZop3vfGKsrX.ke8XuWirGYh1PKgEw44kE/-1x-1.png" alt="" width="580"/&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;div style="display:none"&gt;&lt;![endif]--&gt;&lt;img alt="替代" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iu0tXeBoEQ5M/v3/pidjEfPlU1QWZop3vfGKsrX.ke8XuWirGYh1PKgEw44kE/-1x-1.png" style="width: 100%; display: block; margin-bottom: 4px;" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;/figure&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;研究中国企业、与人合着的 2024 年案例研究《华为：自给自足和逆境中的韧性》的哈佛大学教授威廉·柯比 (William Kirby) 表示，华为“向清洁能源及相关领域的扩张是一个支点，美国的制裁确实加速了其规模和紧迫性”。他说，每年有数万亿美元流入全球能源转型，“这具有非常好的战略意义。” &lt;/p&gt;&lt;a href="https://links.message.bloomberg.com/a/sc/Oa3U-x5KC7IuLj6sRA9BOweXRfHqFHOK8CRxVcHO-B21lW9KCy5TwPxtzZ1TPOiQzxIBHXFXeILiyegFmdSkr66BwaokLZfz4V317mxPxFVCdLLSPYwK8CyMPGCgcHH8UByvYwi4M3c1l4A1ipcqzVSAg3OXw8UvGo3JPehNnFHNji1eaGuz8pHH4WQicmoOKhfVKmI3fXtRgpNfiUsadVZrBaEay6mDzxYfHWUZrBxRzW0vlF6jo_bZ3jDo2HDxd0nwjJYmsVAJOEsvV36vso7yRjWd6lvNc1O0I_iUfFZjjFttnM628pomkR0ezorG6jmDWBIcdtI3q6raaZNYd9np6BBgvS7GcHGvqaQSqIhd1O23abw704eM3oHuEJ5KIbum_YJy7Yv42vQ0kYS7B-lahOR6Xi8BP9_mScG9P_qAe3y2IlIP0psAYFG-koNkxzOn2_FY3_YSOYEVB__0V41zEJrOLGwegVrPgZjgfZYbvKgkMReOSH9fFiIp4cUFpXaIItTph_9m-wz9OA1urt_UWYs40siSEp2Ocd6cwkhFyda03F8MrMuL5IQa_oKjqhZ7YxUZGg/KeFUsvs_fzVGnkTd9oODggHDCMJFVpjh/22" rel="noopener noreferrer" style="font-size: inherit; color: #00e; text-decoration: none !important;" target="_blank" title="华为110亿美元的清洁能源帝国正在开拓新市场"&gt;&lt;div style="display: block; width: 100%; height: 40px; margin: 24px 0 0 0; border: 1px solid; border-radius: 8px; text-align: center; line-height: 40px; font-size: 14px !important; color: #000 !important; text-decoration: none !important;"&gt;继续阅读&lt;/div&gt;&lt;table align="center" cellpadding="0" cellspacing="0" style="margin-top: 20px;" width="auto"&gt;&lt;tr&gt;&lt;td align="center" style="padding: 0;" valign="top"&gt; &lt;a href="https://links.message.bloomberg.com/s/c/jLMhqqEZLFZ6FIvp6uGDHRLsOBVpeW5z1kdmtk7yQ7X5lONFVe7m90AW-l0JS0Thoe-nYpUDYxNxa5dB3_NfFloFHmmhbmDSbxtwhn-wJTQAhMAl6fzP79HCWpjx1Gp4gAMvRop-D5tZMdK1GYhq0qwziPg08lZJtEO5TRZr3o0L52tM-_uWIwtDUG-e8HE0AiMINfoQla4CH5EyWTOzkvc9UahcL1bi9Z6M5qD29L55x7lqijAK0elg4gx7o3ewBPbb7ms1CByBWBSIOx-Ug-SxrxlTTFR8ky1T8m3ajSRZYLY304We7BV0WEIooA03