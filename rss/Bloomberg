: 24px;"&gt;&lt;a href="https://links.message.bloomberg.com/a/sc/D8DMIbHtRB_wX2AHgjXfKjFWa8CVrzz8QffEi5vLuoy5OzoWK4OEQUggMX62s5k-bR0uD5La5sBrm4ixsPrd_AYzjC1p-2vgGqS4mS5wvduM9UDK9L_rO0rK-zg1rdLUkyYaokJQGnhc_WVdTk8BxfY3kzGn1YSLiA8OXSSn26d-LsS1MqwUAoLcEWCWSyRA3p-FU_byGSt30KoPo5Q62Q8jffPGCZi9xkC3gtC5VUeO7JtNjd1e6O3fjWueXh_j7Czco9i3LXC1XIM6Om-qtJ53b3jnqXTerCHmfBFdynMqnY-CLXO6uwi7q9meYMUT_0boaaEX8yz_UEkliHgL0J5lbU_NmRx7W1-ArfqNLjxINXtdClVLDaxPsXQJ3StHIoU8WGuQrtR82Ka9pbnVeL284muZaMRq-gA6OWhtzLhSadcX8LrEpVYF2HWBuXJpRIiLqlJAEwcXRO8NgddLfq8LXWXHmzzD_JUClrc4kFnNQzp44qKXtNVr5KBWcG3yCCISHK1l4tRNkC5kPA/1O73WPkMteYNqntMySSXeaaNnBC6n45J/22" style="font-size: inherit; color: inherit; text-decoration: none;" target="_blank"&gt;&lt;div&gt;&lt;!--[if mso]&gt;&lt;table width="580"&gt;&lt;tr&gt;&lt;td&gt;&lt;img src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/idPLw4hZ4qYc/v1/-1x-1.jpg" alt="" width="580"/&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;div style="display:none"&gt;&lt;![endif]--&gt;&lt;img alt="替代" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/idPLw4hZ4qYc/v1/-1x-1.jpg" style="width: 100%; display: block;" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;/div&gt;&lt;p style="line-height: normal; margin: 12px 0 0 0; color: inherit; text-decoration: none; font-size: 14px !important;"&gt;周末随笔&lt;/p&gt;&lt;h2 style="line-height: normal; font-weight: 700; margin: 12px 0 0 0; font-size: 20px !important;"&gt;为什么机场休息室不能戒烟&lt;/h2&gt;&lt;p style="line-height: 1.4; margin: 12px 0 0 0; color: inherit; text-decoration: none; font-size: 16px !important;"&gt;在这个对香烟充满敌意的世界里，这些房间是奇怪的顽固分子。 &lt;/p&gt;&lt;div style="display: block; width: 100%; height: 40px; text-align: center; line-height: 40px; border: 1px solid; border-radius: 8px; margin: 16px 0 0 0; font-size: 14px !important;"&gt;阅读更多&lt;/div&gt;&lt;/div&gt;&lt;table align="center" cellpadding="0" cellspacing="0" style="margin-top: 20px;" width="auto"&gt;&lt;tr&gt;&lt;td align="center" style="padding: 0;" valign="top"