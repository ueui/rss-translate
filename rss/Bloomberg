]。” &lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style="border-collapse: collapse; padding: 16px 0px;"&gt;&lt;table border="0" cellpadding="0" cellspacing="0" width="100%"&gt;&lt;tr&gt;&lt;td style="border-collapse: collapse; border-radius: 8px; padding-bottom: 18px;"&gt;&lt;table border="0" cellpadding="0" cellspacing="0" width="100%"&gt;&lt;tr&gt;&lt;td style="border-collapse: collapse;" valign="top"&gt; &lt;a href="https://links.message.bloomberg.com/s/c/I9f-wV3DBSnIDCDKlA1R1BXBnrK3w3G0FrwO26tnBLN_FWdCUhZIRzTVByvBoj0LGWVNyt4G5tHT6ZlF4dA5FBBcYdIdkQQq3WGMrITHLpHaLM0XUX38WoGA0eEEs80PmmZNMoK1ldRGrL6X8ZvNBpFqGaVNlTBVl5NJSzfA7ZBFILXtYIrh6wdvnFNQr0yhetlXkta3kGPzyiaiL6jPK751PZJf3eXmtatqJdc-QZVSOq6RHFBLnUkR680ImqHClBZiBCCwpakBgF4zilRhTu_Lo-dlEVw63i_ZgoK3Zzy4DWuIEAeiNag3N7gHavBu1h9swALd6CdUrbezrvK-5F6TKRmJB6E8b_M0sSPCcUqUTxXaGDQlZrwVli8/T6oYpZkCGGOqQ_r1PaOIGwFGwkj54Wyt/18" rel="nofollow" style="color: #000000; text-decoration: none; display: block;" target="_blank"&gt;&lt;!--[if mso]&gt;&lt;table width="550"&gt;&lt;tr&gt;&lt;td&gt;&lt;img alt="" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iL.hyG2HDqp0/v0/550x381.jpg" width="550"/&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt; &lt;div style="display:none"&gt;&lt;![endif]--&gt;&lt;img class="email-ssl-image" height="381" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iL.hyG2HDqp0/v0/550x381.jpg" style="border-radius: 8px 8px 0px 0px; width: 550px; height: 381px;" width="550" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;/a&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td valign="top"&gt; &lt;a href="https://links.message.bloomberg.com/s/c/WBd-u5wcweQ7hp2J-NP6OhJuGjjOC5_uK8eiOB21tlWvQRr55FRz0PxctlUtpzGhZFiR5LSvBFQWlFqhWTVBNERnD8yEvnKkjc48mZK_Vz4n_SoQ59ZcXltOdOt7r1oy60jXTP_rKR_z7pw2Ykq2gBAnxvy4YfJG9pQ4z5dQtTv2ob7M3aGklqMG1qXvyKArt681qgHrp5XRdcXPRmQ85pPxn24wPGhsnPMuOyKRR7dwxLAnkZaJUuvuiEVcO0DlrccXd9_S2srHIqEdwYTVHoPV_bRU0B7T-f3PcIO_zA4Fu4yc-GECvaiKSYLB9lao4Clw0528k-0KyfOQNR