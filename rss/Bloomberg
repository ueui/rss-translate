jWHBFdfxIU/iJMtTqmE1Vns/v0/-1x-1.jpg" alt="" width="580"/&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;div style="display:none"&gt;&lt;![endif]--&gt;&lt;img alt="替代" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iJMtTqmE1Vns/v0/-1x-1.jpg" style="width: 100%; display: block;" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;/div&gt;&lt;p style="line-height: normal; margin: 12px 0 0 0; color: inherit; text-decoration: none; font-size: 14px !important;"&gt;周末面试&lt;/p&gt;&lt;h2 style="line-height: normal; font-weight: 700; margin: 12px 0 0 0; font-size: 20px !important;"&gt;基肖尔·马凯硕：“中国无法再被阻止” &lt;/h2&gt;&lt;p style="line-height: 1.4; margin: 12px 0 0 0; color: inherit; text-decoration: none; font-size: 16px !important;"&gt;这位学者兼作家认为，美国的每场战争都为中国赢得了更多时间。 &lt;/p&gt;&lt;div style="display: block; width: 100%; height: 40px; text-align: center; line-height: 40px; border: 1px solid; border-radius: 8px; margin: 16px 0 0 0; font-size: 14px !important;"&gt;阅读更多&lt;/div&gt;&lt;div style="border-top: 1px solid; margin: 24px 0 0 0;"&gt;&lt;/div&gt;&lt;/div&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;西方曾经认为资本主义将使中国自由化。预测市场建立在对市场作为理性引擎的类似信念之上。 2008年，一群经济学家呼吁让他们摆脱“不必要的政府限制”。约翰·奥瑟斯写道，更宽松的规则&lt;em style="font-size: 16px;"&gt;释放&lt;/em&gt;了创新，但不是经济学家所设想的那种。今天的预测市场更像是在线赌博，而不是技术官僚工具。 &lt;/p&gt;&lt;div style="margin-top: 24px;"&gt;&lt;a href="https://links.message.bloomberg.com/a/sc/qI5jzEX3__7AsCHz4upvs3Fqp1vHZeF81XRYPvD2Ck0RGsKQrn1V0-FAF9ZtZJ9YfZIM_FCWeaYMCxtrxB498POPM1vfaLtJbLNQgzc5ZJ5D1EF68UvJDZl0c4-NaXvWfJ6gkuFpuGWwp0C1uNWPDnWmlPWY1-FLgZkG8fGx8Ppz4otp1yTjepRziKgnj99gYf2Rpc2hj3KZfPr8TOgeGsfTvo-ak5_O-2HsohKXbd9zSTTXLr2dMtbbsJK8YK8_T1glTTStzkcBjiqJju1bMzUbIqAPi98GQdSLueG6caHpvjMP3xHoftCN_KoLIqB_ZL3xm6JOryvwX2gO1DtEK0pDmDlEYrgE7Xbu25mojT-2e8GCO3-MP_RLAHkPgwqv39Y3GIaevWDtzpbHtPgVakBX-Pd3/MnyxjSZDiw-ampJcolohoAFbfUb2DbxH/20" style="font-size: inherit; color: inherit; text-decoration: none;" target="_blank"&gt;&lt;div&gt;&lt;!--[if mso]&gt;&lt;table width="580"&gt;&lt;tr&gt;&lt;td&gt;&lt;img src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iGA4BxJvI2MU/v0/-1x-1.jpg" alt="" width="580"/&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;div style="display:none"&gt;&lt;![endif]--&gt;&lt;img alt="替代" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/iGA4BxJvI2MU/v0/-1x-1.jpg" style="width: 100%; display: block;" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;/div&gt;&lt;p style="line-height: normal; margin: 12px 0 0 0; color: inherit; text-decoration: none; font-size: 14px !important;"&gt;周末随笔&lt;/p&gt;&lt;h2 style="line-height: normal; font-weight: 700; margin: 12px 0 0 0; font-size: 20px !important;"&gt;仍有时间让预测市场发挥作用&lt;/h2&gt;&lt;p style="line-height: 1.4; margin: 12px 0 0 0; color: inherit; text-decoration: none; font-size: 16px !important;"&gt;一项期待已久的基于市场的预测实验正在举步维艰。 &lt;/p&gt;&lt;div style="display: block; width: 100%; height: 40px; text-align: center; line-height: 40px; border: 1px solid; border-radius: 8px; margin: 16px 0 0 0; font-size: 14px !important;"&gt;阅读更多&lt;/div&gt;&lt;div style="border-top: 1px solid; margin: 24px 0 0 0;"&gt;&lt;/div&gt;&lt;/div&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;预测市场将庞大的现实压缩为一个数字。美国政治有自己的版本：汽油价格。尽管现在家庭在汽油上的支出低于汽车、医疗保健或高等教育的支出，但油价仍然有能力左右总统的任期。凯文·克劳利写道，随着伊朗战争推高油价，美国人可能不太关心冲突的地缘政治利益，而更关心加油的成本。 &lt;/p&gt;&lt;div style="margin-top: 24px;"&gt;&lt;a href="https://links.message.bloomberg.com/a/sc/DSRCdh9CLgD3b8aXx1Nn_T4kyl-6EhaDiK1-C94yUsW1RINsaNtdAlgf_VVqVnN7lZK8C8ECsUFEy9IqUGpe5CxVQlIbblqBKz8dXGhG_fX32lhSuPM-B2gPuo3M4E8jiRJ-YSxKsuJ1rF3c9MnsGQsybw3-grWOF7Kl7ZOTRnietOrAxERBVKMiefedQ5PpyYZ8cO2SltDiOaycyODpZOAbERgYLoFLSANu0Ce7xDZn486rJSf8N_5ms64Bf2xLB83iXxhs0LwY_2DLhDHIZk_xkL91k5JKh3mTDzBR87Un5UWKLw5HsK38wDXyI3IwT3CqHamdhpckb_soqUt3A8eT7LdHz4NXbz4p6SdW_BWubEbeAQA9-Hk_EeSw9fF2hRgFew2hrQ4AMnwxeDlbpw/ZjGKkTGurLI38SJGlf6Q_MYeUFnWNkTH/20" style="font-size: inherit; color: inherit; text-decoration: none;" target="_blank"&gt;&lt;div&gt;&lt;!--[if mso]&gt;&lt;table width="580"&gt;&lt;tr&gt;&lt;td&gt;&lt;img src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/ieBjPVb8SSpc/v0/-1x-1.jpg" alt="" width="580"/&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;div style="display:none"&gt;&lt;![endif]--&gt;&lt;img alt="替代" src="https://assets.bwbx.io/images/users/iqjWHBFdfxIU/ieBjPVb8SSpc/v0/-1x-1.jpg" style="width: 100%; display: block;" /&gt;&lt;!--[if mso]&gt;&lt;/div&gt;&lt;![endif]--&gt;&lt;/div&gt;&lt;p style="line-height: normal; margin: 12px 0 0 0; color: inherit; text-decoration: none; font-size: 14px !important;"&gt;周末随笔&lt;/p&gt;&lt;h2 style="line-height: normal; font-weight: 700; margin: 12px 0 0 0; font-size: 20px !important;"&gt;天然气价格是美国政治中最重要的数字&lt;/h2&gt;&lt;p style="line-height: 1.4; margin: 12px 0 0 0; color: inherit; text-decoration: none; font-size: 16px !important;"&gt;汽油的政治权力仍然可以决定总统职位的成败。 &lt;/p&gt;&lt;div style="display: block; width: 100%; height: 40px; text-align: center; line-height: 40px; border: 1px solid; border-radius: 8px; margin: 16px 0 0 0; font-size: 14px !important;"&gt;阅读更多&lt;/div&gt;&lt;div style="border-top: 1px solid; margin: 24px 0 0 0;"&gt;&lt;/div&gt;&lt;/div&gt;&lt;p style="margin-top: 24px; font-size: 16px;"&gt;汽油的政治力量与汽车所代表的东西密不可分：自由、身份和记忆。对于从父母和祖父母那里继承心爱车辆的 X 一代和千禧一代来说，这种象征意义可能会让他们难以放手——即使汽车几乎无法行驶。汉娜·埃利奥特 (Hannah Elliott) 探讨了即将到来的老爷车转让所带来的情感和财务复杂性，从捷豹汽车的家庭纠纷到继承人修复老化的阿尔法罗密欧。 &lt;/p&gt;&lt;div style="margin-top: 24px;"&gt;&lt;a href="https://links.message.bloomberg.com/a/sc/HaCoqcgGkLGBAF1EsTJwWUQB_RjDHVfHBo4MNfDyWX6WdTb4H7eO6mvOMe_ICS6XWhX1NpBraXgK9qQU7FT9XHWLTYJ6Cu2vrdMMFktzn9GCxhuQyBDXup8f9tmOnMLotqYW_zB2yrxDH1Fr3dX7ujhDafBV6P6qeE7yrnGIWQlD5RoElUew4GariDmJSofaCP1GnZEcu0xlV_uKaI1s6XE3c3KRhxyfmqw-GrS9OJKZuNjJOtq_4qCMDeZlTxiTYLfBBPLxaZPxY0hF6_mkwApQ4Xtk1s7P_36XrRCOm00hMoqj6YS6D6oAAJfrgPOHXkTho7Lha1r9emt3jXO2HDMhdqvj13hIhZ4GU9P42tBvg1TxI3vbmBV6xENqkXOGFZWbWnKXBjZ4Zoqxb6Aiz4bqr-4/yXeahDYEubzuadd7IJgKB9dgi-lkNqIV/20" style="font-size: inherit; color: inherit; text-decoration: none;" target="_blank"&gt;&lt;div&gt;&